{
  "name": "runtara-frontend",
  "description": "Runtara frontend application",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "author": "Runtara",
  "repository": {
    "type": "git",
    "url": "https://github.com/runtara/runtara.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:watch": "vite build --watch",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report e2e-report",
    "test:e2e:docker": "docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:local": "playwright test --project=e2e",
    "test:e2e:mocked": "playwright test --project=mocked",
    "test:e2e:mocked:headed": "playwright test --project=mocked --headed",
    "test:e2e:mocked:update": "playwright test --project=mocked --update-snapshots",
    "test:e2e:smoke:docker": "E2E_PROJECT=smoke docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit",
    "generate-api-runtime-local": "swagger-typescript-api generate --axios -p http://localhost:7001/api/runtime/openapi/docs.json -o src/generated -n RuntaraRuntimeApi.ts",
    "generate-api-management-local": "swagger-typescript-api generate --axios -p http://localhost:8080/api/management/openapi/docs.json -o src/generated -n RuntaraManagementApi.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "knip": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.1.5",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "@tanstack/react-query": "^5.55.4",
    "@tanstack/react-table": "^8.20.5",
    "@testing-library/dom": "^10.4.0",
    "@xyflow/react": "^12.6.4",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "immer": "^10.1.1",
    "json-edit-react": "^1.23.1",
    "lucide-react": "^0.439.0",
    "oidc-client-ts": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "react-oidc-context": "^3.2.0",
    "react-router": "^7.12.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^14.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.15",
    "@storybook/addon-onboarding": "^8.6.15",
    "@storybook/addon-themes": "^8.6.15",
    "@storybook/react": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@storybook/test": "^8.6.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^6.3.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.45",
    "prettier": "3.3.3",
    "recharts": "^2.15.1",
    "storybook": "^8.6.18",
    "swagger-typescript-api": "^13.0.22",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.1.3",
    "wait-on": "^9.0.5",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "flatted": "3.4.2",
    "dompurify": "3.3.2",
    "serialize-javascript": "7.0.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.21.2",
    "@rollup/rollup-darwin-x64": "^4.21.2",
    "@rollup/rollup-linux-arm64-gnu": "^4.21.2",
    "@rollup/rollup-linux-arm64-musl": "^4.21.2",
    "@rollup/rollup-linux-x64-gnu": "^4.21.2",
    "@rollup/rollup-linux-x64-musl": "^4.21.2"
  }
}
