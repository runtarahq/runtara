# Runtara Frontend Environment Variables

# API URLs
VITE_RUNTARA_API_BASE_URL=http://localhost:8080

# Plausible Analytics (optional). Leave blank to disable.
VITE_RUNTARA_PLAUSIBLE_DOMAIN=
VITE_RUNTARA_PLAUSIBLE_HOST=

# Email trigger domain
VITE_EMAIL_EVENTS_DOMAIN=events.example.com

# OIDC Configuration (required)
VITE_OIDC_AUTHORITY=your_oidc_authority_url
VITE_OIDC_CLIENT_ID=your_client_id
VITE_OIDC_AUDIENCE=your_audience_url

# E2E Testing - Auth0/OIDC Configuration
# auth.setup.ts uses the Client Credentials Grant with a dedicated test app.

# Auth0 test application (client credentials grant enabled)
TEST_APP_CLIENT_ID=your_test_app_client_id
TEST_APP_CLIENT_SECRET=your_test_app_client_secret

# Auth0 organization ID (optional, for organization-based login)
TEST_ORG_ID=org_xxxxx

# E2E Testing - Playwright Configuration (optional)
# Set this to override the default localhost URL for tests
# PLAYWRIGHT_BASE_URL=http://localhost:4173

# =============================================================================
# GitHub Actions Secrets Required for CI Smoke Tests
# =============================================================================
# Add these secrets to your GitHub repository settings:
#
# Required:
#   TEST_APP_CLIENT_ID     - Auth0 test app client ID (with client_credentials grant)
#   TEST_APP_CLIENT_SECRET - Auth0 test app client secret
#   VITE_OIDC_AUTHORITY    - OIDC provider authority URL (for app config)
#   VITE_OIDC_CLIENT_ID    - OIDC client ID (for app config)
#   VITE_OIDC_AUDIENCE     - OIDC audience URL (for app config)
#
# Optional:
#   TEST_ORG_ID            - Auth0 organization ID
