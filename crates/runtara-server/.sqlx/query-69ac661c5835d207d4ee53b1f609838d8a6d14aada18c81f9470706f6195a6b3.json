{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT parent_version, child_scenario_id, child_version_requested, child_version_resolved, step_id\n            FROM scenario_dependencies\n            WHERE parent_tenant_id = $1\n                AND parent_scenario_id = $2\n                AND ($3::INTEGER IS NULL OR parent_version = $3)\n            ORDER BY CASE WHEN $3 IS NULL THEN parent_version ELSE 0 END DESC, step_id\n            ",
