            "columns": 1,
            "items": [
              {
                "id": "col_table_i0",
                "child": { "id": "n_status", "type": "block", "blockId": "rate_limit_status" }
              }
            ]
          }
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "interval",
      "label": "Interval",
      "type": "select",
