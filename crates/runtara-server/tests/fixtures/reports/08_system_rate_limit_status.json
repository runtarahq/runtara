          { "field": "requests_remaining", "label": "Remaining", "format": "number", "align": "right" },
          { "field": "utilization_pct", "label": "Utilization", "format": "percent", "align": "right" },
          {
            "field": "throttled",
            "label": "Throttled",
            "format": "pill",
            "pillVariants": { "true": "warning", "false": "muted" }
