        "source": "static",
        "values": [
          { "label": "Last hour", "value": "1h" },
          { "label": "Last 24 hours", "value": "24h" },
          { "label": "Last 7 days", "value": "7d" },
          { "label": "Last 30 days", "value": "30d" }
        ]
      }
    }
  ],
  "blocks": [
    {
      "id": "rate_limit_status",
      "type": "table",
      "title": "Rate limit status",
      "source": {
        "kind": "system",
        "entity": "connection_rate_limit_status",
        "mode": "filter",
        "interval": "1h"
      },
      "table": {
        "columns": [
