        ]
      }
    },
    {
      "id": "rate_limit_usage",
      "type": "metric",
      "title": "Overall utilization",
      "source": {
        "kind": "system",
        "entity": "connection_rate_limit_status",
        "mode": "aggregate",
        "interval": "1h",
        "aggregates": [
          { "alias": "value", "op": "avg", "field": "utilization_pct" }
        ]
      },
      "metric": {
        "valueField": "value",
        "label": "Utilization",
        "format": "percent"
      }
    }
