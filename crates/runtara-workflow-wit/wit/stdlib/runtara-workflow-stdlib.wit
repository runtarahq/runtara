// Canonical WIT contract for the shared workflow stdlib component.
//
// The stdlib owns reusable JSON-heavy workflow semantics. Direct-emitted
// workflow logic should call these functions instead of embedding serde,
// mapping, condition, filter, group-by, or switch implementations in every
// workflow artifact.

package runtara:workflow-stdlib@0.1.0;

interface json {
    record agent-retry-error {
        payload: list<u8>,
        retryable: bool,
        rate-limited: bool,
    }

    init-manifest: func(manifest: list<u8>) -> result<_, string>;

    build-source: func(
        data: list<u8>,
        variables: list<u8>,
        steps: list<u8>,
    ) -> result<list<u8>, string>;

    apply-mapping: func(
        mapping-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    eval-condition: func(
        condition-id: u32,
        source: list<u8>,
    ) -> result<bool, string>;

    process-switch: func(
        switch-id: u32,
        source: list<u8>,
    ) -> result<string, string>;

    value-switch: func(
        switch-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    split-items: func(
        split-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    split-item-count: func(
        split-id: u32,
        source: list<u8>,
    ) -> result<u32, string>;

    split-item: func(
        split-id: u32,
        source: list<u8>,
        index: u32,
    ) -> result<list<u8>, string>;

    split-iteration-variables: func(
        split-id: u32,
        source: list<u8>,
        item: list<u8>,
        index: u32,
    ) -> result<list<u8>, string>;

    split-validate-input: func(
        split-id: u32,
        item: list<u8>,
        index: u32,
    ) -> result<_, string>;

    split-validate-output: func(
        split-id: u32,
        output: list<u8>,
        index: u32,
    ) -> result<_, string>;

    split-initial-results: func(
        split-id: u32,
    ) -> result<list<u8>, string>;

    split-append-output: func(
        split-id: u32,
        results: list<u8>,
        output: list<u8>,
    ) -> result<list<u8>, string>;

    split-append-error: func(
        split-id: u32,
        results: list<u8>,
        error: string,
        index: u32,
    ) -> result<list<u8>, string>;

    split-output: func(
        split-id: u32,
        source: list<u8>,
        results: list<u8>,
    ) -> result<list<u8>, string>;

    filter: func(
        filter-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    log-event: func(
        log-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    log: func(
        log-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    error-event: func(
        error-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    error: func(
        error-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    error-steps: func(
        step-id: string,
        error: list<u8>,
        steps: list<u8>,
    ) -> result<list<u8>, string>;

    group-by: func(
        group-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    delay-duration-ms: func(
        delay-id: u32,
        source: list<u8>,
    ) -> result<u64, string>;

    delay: func(
        delay-id: u32,
        source: list<u8>,
        duration-ms: u64,
    ) -> result<list<u8>, string>;

    agent-output: func(
        agent-id: u32,
        source: list<u8>,
        output: list<u8>,
    ) -> result<list<u8>, string>;

    agent-validate-input: func(
        agent-id: u32,
        input: list<u8>,
    ) -> result<list<u8>, string>;

    agent-connection-input: func(
        agent-id: u32,
        input: list<u8>,
    ) -> result<list<u8>, string>;

    agent-cache-key: func(
        agent-id: u32,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    agent-retry-sleep-key: func(
        checkpoint-id: string,
        attempt-number: u32,
    ) -> result<list<u8>, string>;

    agent-retry-delay-ms: func(
        attempt-number: u32,
        total-attempts: u32,
        base-delay-ms: u64,
        max-delay-ms: u64,
        retry-after-ms: option<u64>,
    ) -> result<u64, string>;

    agent-error-info: func(
        code: string,
        message: string,
        category: string,
        severity: string,
        retryable: bool,
        retry-after-ms: option<u64>,
        attributes: option<string>,
    ) -> result<list<u8>, string>;

    agent-retry-error-info: func(
        code: string,
        message: string,
        category: string,
        severity: string,
        retryable: bool,
        retry-after-ms: option<u64>,
        attributes: option<string>,
    ) -> result<agent-retry-error, string>;

    agent-error: func(
        agent-id: u32,
        code: string,
        message: string,
        category: string,
        severity: string,
        retryable: bool,
        retry-after-ms: option<u64>,
        attributes: option<string>,
    ) -> result<list<u8>, string>;

    agent-error-from-info: func(
        agent-id: u32,
        error-info: list<u8>,
    ) -> result<list<u8>, string>;

    agent-debug-error: func(
        agent-id: u32,
        error: list<u8>,
    ) -> result<list<u8>, string>;

    step-debug-start: func(
        step-id: string,
        source: list<u8>,
    ) -> result<list<u8>, string>;

    step-debug-end: func(
        step-id: string,
        source: list<u8>,
    ) -> result<list<u8>, string>;
}

world workflow-stdlib {
    export json;
}
