{
  "name": "Split with input/output schemas",
  "description": "Each iteration's data must have a 'value' field; the inner Finish must produce a 'processed' field. Both schemas are honored at runtime.",
  "inputSchema": {
    "items": { "type": "array", "required": true }
  },
  "steps": {
    "split": {
      "stepType": "Split",
      "id": "split",
      "config": {
        "value": { "valueType": "reference", "value": "data.items" },
        "sequential": true
      },
      "inputSchema": {
        "value": { "type": "string", "required": true }
      },
      "outputSchema": {
        "processed": { "type": "object", "required": true }
      },
      "subgraph": {
        "name": "Item Processing",
        "steps": {
          "transform": {
            "stepType": "Agent",
            "id": "transform",
            "agentId": "transform",
            "capabilityId": "map-fields",
            "inputMapping": {
              "source": { "valueType": "reference", "value": "data" },
              "mapping": {
                "valueType": "immediate",
                "value": { "value": "$.value" }
              }
            }
          },
          "finish": {
            "stepType": "Finish",
            "id": "finish",
            "inputMapping": {
              "processed": { "valueType": "reference", "value": "steps.transform.outputs" }
            }
          }
        },
        "entryPoint": "transform",
        "executionPlan": [
          { "fromStep": "transform", "toStep": "finish" }
        ]
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "results": { "valueType": "reference", "value": "steps.split.outputs" }
      }
    }
  },
  "entryPoint": "split",
  "executionPlan": [
    { "fromStep": "split", "toStep": "finish" }
  ]
}
