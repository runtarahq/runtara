{
  "name": "AiAgent Single Shot",
  "description": "Direct-emitter fixture: a single-shot AiAgent (no tools, memory, structured output, or MCP) that summarizes the input and finishes with the response.",
  "durable": true,
  "steps": {
    "ai": {
      "stepType": "AiAgent",
      "id": "ai",
      "name": "Answer",
      "connectionId": "openai-conn",
      "config": {
        "systemPrompt": { "valueType": "immediate", "value": "You are a helpful assistant." },
        "userPrompt": { "valueType": "reference", "value": "data.question" },
        "provider": "openai",
        "model": "gpt-4o"
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "answer": { "valueType": "reference", "value": "steps.ai.outputs.response" }
      }
    }
  },
  "entryPoint": "ai",
  "executionPlan": [
    { "fromStep": "ai", "toStep": "finish" }
  ],
  "variables": {},
  "inputSchema": {},
  "outputSchema": {}
}
