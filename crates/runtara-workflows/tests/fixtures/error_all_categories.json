{
  "name": "Error Categories",
  "description": "Workflow demonstrating error categories: transient, permanent (technical), permanent (business)",
  "steps": {
    "check_condition": {
      "stepType": "Conditional",
      "id": "check_condition",
      "name": "Check Error Type",
      "condition": {
        "type": "operation",
        "op": "EQ",
        "arguments": [
          {
            "valueType": "reference",
            "value": "data.errorType"
          },
          {
            "valueType": "immediate",
            "value": "transient"
          }
        ]
      }
    },
    "check_business": {
      "stepType": "Conditional",
      "id": "check_business",
      "name": "Check Permanent Error Kind",
      "condition": {
        "type": "operation",
        "op": "EQ",
        "arguments": [
          {
            "valueType": "reference",
            "value": "data.errorType"
          },
          {
            "valueType": "immediate",
            "value": "business"
          }
        ]
      }
    },
    "error_transient": {
      "stepType": "Error",
      "id": "error_transient",
      "name": "Transient Error",
      "category": "transient",
      "code": "NETWORK_TIMEOUT",
      "message": "Network request timed out",
      "severity": "warning"
    },
    "error_permanent_business": {
      "stepType": "Error",
      "id": "error_permanent_business",
      "name": "Permanent Business Error",
      "category": "permanent",
      "code": "CREDIT_LIMIT_EXCEEDED",
      "message": "Order amount exceeds credit limit",
      "severity": "warning"
    },
    "error_permanent_technical": {
      "stepType": "Error",
      "id": "error_permanent_technical",
      "name": "Permanent Technical Error",
      "category": "permanent",
      "code": "RESOURCE_NOT_FOUND",
      "message": "Requested resource does not exist",
      "severity": "error"
    }
  },
  "entryPoint": "check_condition",
  "executionPlan": [
    {
      "fromStep": "check_condition",
      "toStep": "error_transient",
      "label": "true"
    },
    {
      "fromStep": "check_condition",
      "toStep": "check_business",
      "label": "false"
    },
    {
      "fromStep": "check_business",
      "toStep": "error_permanent_business",
      "label": "true"
    },
    {
      "fromStep": "check_business",
      "toStep": "error_permanent_technical",
      "label": "false"
    }
  ],
  "variables": {},
  "inputSchema": {
    "errorType": {
      "type": "string",
      "description": "Type of error to trigger",
      "required": true
    }
  },
  "outputSchema": {}
}
