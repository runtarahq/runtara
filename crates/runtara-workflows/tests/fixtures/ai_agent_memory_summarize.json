{
  "name": "AiAgent Memory Summarize",
  "description": "Direct-emitter fixture: an AiAgent with conversation memory, one tool, and Summarize-strategy compaction (maxMessages 2). The tool loop accumulates four messages; summarize compaction replaces the oldest two with one LLM-generated summary message before the memory save.",
  "durable": true,
  "steps": {
    "ai": {
      "stepType": "AiAgent",
      "id": "ai",
      "name": "Chat",
      "connectionId": "openai-conn",
      "config": {
        "systemPrompt": { "valueType": "immediate", "value": "Use the echo tool, then answer." },
        "userPrompt": { "valueType": "reference", "value": "data.q" },
        "provider": "openai",
        "model": "gpt-4o",
        "maxIterations": 5,
        "memory": {
          "conversationId": { "valueType": "reference", "value": "data.session" },
          "compaction": { "maxMessages": 2, "strategy": "summarize" }
        }
      }
    },
    "echo": {
      "stepType": "Agent",
      "id": "echo",
      "name": "Echo",
      "agentId": "utils",
      "capabilityId": "return-input",
      "inputMapping": {
        "value": { "valueType": "reference", "value": "data.q" }
      }
    },
    "mem": {
      "stepType": "Agent",
      "id": "mem",
      "name": "Memory",
      "agentId": "object_model",
      "capabilityId": "load-memory",
      "connectionId": "om-conn",
      "inputMapping": {}
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "answer": { "valueType": "reference", "value": "steps.ai.outputs.response" }
      }
    }
  },
  "entryPoint": "ai",
  "executionPlan": [
    { "fromStep": "ai", "toStep": "echo", "label": "echo" },
    { "fromStep": "ai", "toStep": "mem", "label": "memory" },
    { "fromStep": "ai", "toStep": "finish" }
  ],
  "variables": {},
  "inputSchema": {},
  "outputSchema": {}
}
