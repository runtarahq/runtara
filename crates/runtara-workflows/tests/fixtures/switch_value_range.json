{
  "name": "Range Value Switch Workflow",
  "description": "A workflow that selects output using BETWEEN and RANGE switch cases",
  "steps": {
    "switch": {
      "stepType": "Switch",
      "id": "switch",
      "name": "Classify Score",
      "config": {
        "value": {
          "valueType": "reference",
          "value": "data.score"
        },
        "cases": [
          {
            "matchType": "BETWEEN",
            "match": [80, 100],
            "output": {
              "grade": "high"
            }
          },
          {
            "matchType": "RANGE",
            "match": {
              "gte": 50,
              "lt": 80
            },
            "output": {
              "grade": "mid"
            }
          }
        ],
        "default": {
          "grade": "low"
        }
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "grade": {
          "valueType": "reference",
          "value": "steps.switch.outputs.grade"
        }
      }
    }
  },
  "entryPoint": "switch",
  "executionPlan": [
    {
      "fromStep": "switch",
      "toStep": "finish"
    }
  ],
  "variables": {},
  "inputSchema": {
    "score": {
      "type": "number"
    }
  },
  "outputSchema": {
    "grade": {
      "type": "string"
    }
  }
}
