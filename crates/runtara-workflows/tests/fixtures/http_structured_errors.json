{
  "name": "HTTP Structured Errors",
  "description": "HTTP call with transient retries handled by the Agent (maxRetries) and a permanent-error terminal on exhaustion.",
  "steps": {
    "call_api": {
      "stepType": "Agent",
      "id": "call_api",
      "name": "Make HTTP Request",
      "agentId": "http",
      "capabilityId": "http-request",
      "maxRetries": 3,
      "retryDelay": 1000,
      "inputMapping": {
        "method": {
          "valueType": "immediate",
          "value": "GET"
        },
        "url": {
          "valueType": "reference",
          "value": "data.apiUrl"
        },
        "failOnError": {
          "valueType": "immediate",
          "value": true
        }
      }
    },
    "handle_success": {
      "stepType": "Log",
      "id": "handle_success",
      "message": "API call succeeded",
      "context": {
        "response": {
          "valueType": "reference",
          "value": "steps.call_api.outputs"
        }
      }
    },
    "handle_permanent_error": {
      "stepType": "Error",
      "id": "handle_permanent_error",
      "name": "Permanent API Error",
      "category": "permanent",
      "code": "API_ERROR",
      "message": "API returned a permanent error (or exhausted transient retries)",
      "severity": "error",
      "context": {
        "originalError": {
          "valueType": "reference",
          "value": "__error.message"
        },
        "statusCode": {
          "valueType": "reference",
          "value": "__error.attributes.status_code"
        }
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "result": {
          "valueType": "reference",
          "value": "steps.call_api.outputs"
        }
      }
    }
  },
  "entryPoint": "call_api",
  "executionPlan": [
    {
      "fromStep": "call_api",
      "toStep": "handle_success"
    },
    {
      "fromStep": "handle_success",
      "toStep": "finish"
    },
    {
      "fromStep": "call_api",
      "toStep": "handle_permanent_error",
      "label": "onError"
    }
  ],
  "variables": {},
  "inputSchema": {
    "apiUrl": {
      "type": "string",
      "description": "URL to call",
      "required": true
    }
  },
  "outputSchema": {}
}
