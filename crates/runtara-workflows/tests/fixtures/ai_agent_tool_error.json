{
  "name": "AiAgent Tool Error",
  "description": "Direct-emitter fixture: an AiAgent whose tool (utils/calculate) fails when the LLM calls it without an `expression`. The tool error must be fed back to the model as the tool result so the loop continues and completes, rather than failing the workflow.",
  "durable": true,
  "steps": {
    "ai": {
      "stepType": "AiAgent",
      "id": "ai",
      "name": "Agent",
      "connectionId": "openai-conn",
      "config": {
        "systemPrompt": {
          "valueType": "immediate",
          "value": "Use the calc tool, then answer."
        },
        "userPrompt": {
          "valueType": "reference",
          "value": "data.q"
        },
        "provider": { "valueType": "immediate", "value": "openai" },
        "model": { "valueType": "immediate", "value": "gpt-4o" },
        "maxIterations": 5
      }
    },
    "calc": {
      "stepType": "Agent",
      "id": "calc",
      "name": "Calc",
      "agentId": "utils",
      "capabilityId": "calculate",
      "inputMapping": {
        "expression": {
          "valueType": "reference",
          "value": "data.q"
        },
        "variables": {
          "valueType": "immediate",
          "value": {}
        }
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "answer": {
          "valueType": "reference",
          "value": "steps.ai.outputs.response"
        }
      }
    }
  },
  "entryPoint": "ai",
  "executionPlan": [
    {
      "fromStep": "ai",
      "toStep": "calc",
      "label": "calc"
    },
    {
      "fromStep": "ai",
      "toStep": "finish"
    }
  ],
  "variables": {},
  "inputSchema": {},
  "outputSchema": {}
}
