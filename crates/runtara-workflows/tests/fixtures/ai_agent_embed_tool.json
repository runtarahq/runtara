{
  "name": "AiAgent EmbedWorkflow Tool",
  "description": "Direct-emitter fixture: an AiAgent whose tool is an EmbedWorkflow target. The LLM calls the embed tool with a city, the composed child workflow returns a forecast, and the agent answers.",
  "durable": true,
  "steps": {
    "ai": {
      "stepType": "AiAgent",
      "id": "ai",
      "name": "Agent",
      "connectionId": "openai-conn",
      "config": {
        "systemPrompt": {
          "valueType": "immediate",
          "value": "Use the get_weather tool, then answer."
        },
        "userPrompt": {
          "valueType": "reference",
          "value": "data.q"
        },
        "provider": "openai",
        "model": "gpt-4o",
        "maxIterations": 5
      }
    },
    "tool_weather": {
      "stepType": "EmbedWorkflow",
      "id": "tool_weather",
      "name": "Get Weather",
      "childWorkflowId": "weather-workflow",
      "childVersion": "latest"
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "answer": {
          "valueType": "reference",
          "value": "steps.ai.outputs.response"
        }
      }
    }
  },
  "entryPoint": "ai",
  "executionPlan": [
    {
      "fromStep": "ai",
      "toStep": "tool_weather",
      "label": "get_weather"
    },
    {
      "fromStep": "ai",
      "toStep": "finish"
    }
  ],
  "variables": {},
  "inputSchema": {},
  "outputSchema": {}
}
