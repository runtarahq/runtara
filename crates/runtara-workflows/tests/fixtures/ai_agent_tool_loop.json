{
  "name": "AiAgent Tool Loop",
  "description": "Direct-emitter fixture: an AiAgent with a single Agent-capability tool (utils/return-input). The LLM calls the tool, then returns text.",
  "durable": true,
  "steps": {
    "ai": {
      "stepType": "AiAgent",
      "id": "ai",
      "name": "Agent",
      "connectionId": "openai-conn",
      "config": {
        "systemPrompt": { "valueType": "immediate", "value": "Use the echo tool, then answer." },
        "userPrompt": { "valueType": "reference", "value": "data.q" },
        "provider": "openai",
        "model": "gpt-4o",
        "maxIterations": 5
      }
    },
    "echo": {
      "stepType": "Agent",
      "id": "echo",
      "name": "Echo",
      "agentId": "utils",
      "capabilityId": "return-input",
      "inputMapping": {
        "value": { "valueType": "reference", "value": "data.q" }
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "answer": { "valueType": "reference", "value": "steps.ai.outputs.response" }
      }
    }
  },
  "entryPoint": "ai",
  "executionPlan": [
    { "fromStep": "ai", "toStep": "echo", "label": "echo" },
    { "fromStep": "ai", "toStep": "finish" }
  ],
  "variables": {},
  "inputSchema": {},
  "outputSchema": {}
}
