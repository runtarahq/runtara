                "value": "data.item"
              }
            }
          }
        },
        "executionPlan": [
          {
            "fromStep": "tick",
            "toStep": "finish"
          }
        ]
      }
    },
    "finish": {
      "stepType": "Finish",
      "id": "finish",
      "inputMapping": {
        "results": {
          "valueType": "reference",
          "value": "steps.split.outputs"
        }
      }
    }
  },
  "entryPoint": "split",
  "executionPlan": [
    {
      "fromStep": "split",
