{
  "name": "minimal_control",
  "description": "Minimal control: Conditional.false -> Agent -> [ai-tools:text-completion, ai-tools:embed-text]. Both fan-out branches MUST fire for the run to be considered passing. This deploys and runs successfully against any tenant with a working OpenAI connection. Mirrors the exact fan-out shape of miss_gate in the failing case at the smallest possible scale; the bug does NOT reproduce here, proving the small-scale fan-out scheduler is fine.",
  "entryPoint": "cond",
  "executionPlan": [
    {"fromStep": "cond",        "label": "true",  "toStep": "fast_finish"},
    {"fromStep": "cond",        "label": "false", "toStep": "fan_step"},
    {"fromStep": "fan_step",    "label": "next",  "toStep": "left_text"},
    {"fromStep": "fan_step",    "label": "next",  "toStep": "right_embed"},
    {"fromStep": "left_text",   "label": "next",  "toStep": "finish"},
    {"fromStep": "right_embed", "label": "next",  "toStep": "finish"}
  ],
  "steps": {
    "cond": {
      "id": "cond",
      "stepType": "Conditional",
      "condition": {
        "type": "operation",
        "op": "EQ",
        "arguments": [
          {"value": "x", "valueType": "immediate"},
          {"value": "y", "valueType": "immediate"}
        ]
      }
    },
    "fast_finish": {
      "id": "fast_finish",
      "stepType": "Finish",
      "inputMapping": {
        "out": {"value": "true_branch", "valueType": "immediate"}
      }
    },
    "fan_step": {
      "id": "fan_step",
      "stepType": "Agent",
      "agentId": "text",
      "capabilityId": "render-template",
      "inputMapping": {
        "context": {"value": {}, "valueType": "composite"},
        "text":    {"value": "pencil item", "valueType": "immediate"}
      }
    },
    "left_text": {
      "id": "left_text",
      "stepType": "Agent",
      "agentId": "ai-tools",
      "capabilityId": "text-completion",
      "connectionId": "<openai-connection-id>",
      "inputMapping": {
        "model":      {"value": "gpt-4o-mini",         "valueType": "immediate"},
        "max_tokens": {"value": 20,                    "valueType": "immediate"},
        "prompt":     {"value": "Reply with just OK.", "valueType": "immediate"}
      }
    },
    "right_embed": {
      "id": "right_embed",
      "stepType": "Agent",
      "agentId": "ai-tools",
      "capabilityId": "embed-text",
      "connectionId": "<openai-connection-id>",
      "inputMapping": {
        "model":     {"value": "text-embedding-3-small", "valueType": "immediate"},
        "dimension": {"value": 1536,                     "valueType": "immediate"},
        "texts": {
          "value":     [{"value": "steps.fan_step.outputs", "valueType": "reference"}],
          "valueType": "composite"
        }
      }
    },
    "finish": {
      "id": "finish",
      "stepType": "Finish",
      "inputMapping": {
        "left_output":  {"value": "steps.left_text.outputs",   "valueType": "reference"},
        "right_output": {"value": "steps.right_embed.outputs", "valueType": "reference"}
      }
    }
  }
}
