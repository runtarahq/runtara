{
  "name": "Example: Public API call",
  "description": "Makes an outbound HTTP GET with the HTTP agent and returns the response status. Demonstrates an Agent step calling an external endpoint. Input: {}.",
  "entryPoint": "fetch",
  "steps": {
    "fetch": {
      "id": "fetch",
      "name": "Fetch a URL",
      "stepType": "Agent",
      "agentId": "http",
      "capabilityId": "http-request",
      "inputMapping": {
        "method": { "valueType": "immediate", "value": "GET" },
        "url": { "valueType": "immediate", "value": "https://example.com" },
        "response_type": { "valueType": "immediate", "value": "text" }
      }
    },
    "done": {
      "id": "done",
      "name": "Return result",
      "stepType": "Finish",
      "inputMapping": {
        "status": { "valueType": "reference", "value": "steps.fetch.outputs.status_code" },
        "success": { "valueType": "reference", "value": "steps.fetch.outputs.success" }
      }
    }
  },
  "executionPlan": [
    { "fromStep": "fetch", "toStep": "done" }
  ]
}
