                    "orderId": {
                      "valueType": "reference",
                      "value": "{{ variables.order.id }}",
                      "type": "string"
                    },
                    "lines": {
                      "valueType": "reference",
                      "value": "{{ variables.order.lines }}",
                      "type": "json"
                    }
                  }
                }
              },
              "renderingParameters": {
                "x": 900,
                "y": 24
              }
            },
            "quote_carriers": {
              "name": "Quote carriers",
