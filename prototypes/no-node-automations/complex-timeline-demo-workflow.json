                }
              },
              "renderingParameters": {
                "x": 1116,
                "y": 24
              }
            },
            "choose_carrier_lane": {
              "name": "Choose carrier lane",
              "description": "Switch between express, economy, international, and manual freight lanes.",
              "stepType": "Switch",
              "config": {
                "value": {
