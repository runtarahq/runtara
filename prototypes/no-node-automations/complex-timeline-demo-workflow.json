                  "value": "{{ steps.quote_carriers.output.recommendedLane }}",
                  "type": "string"
                },
                "cases": [
                  {
                    "match": "express",
                    "matchType": "EQ",
                    "output": {
                      "lane": "express"
                    },
                    "route": "express"
                  },
                  {
                    "match": "economy",
                    "matchType": "EQ",
                    "output": {
                      "lane": "economy"
                    },
                    "route": "economy"
                  },
                  {
                    "match": "international",
                    "matchType": "EQ",
                    "output": {
                      "lane": "international"
                    },
                    "route": "international"
                  }
                ],
                "default": {
                  "lane": "manual"
                }
              },
              "renderingParameters": {
                "x": 1332,
                "y": 24
              }
            },
            "book_express": {
              "name": "Book express shipment",
              "stepType": "Agent",
              "agentId": "shipping",
              "capabilityId": "book-express",
              "renderingParameters": {
                "x": 1548,
                "y": -72
              }
            },
            "book_economy": {
              "name": "Book economy shipment",
              "stepType": "Agent",
              "agentId": "shipping",
              "capabilityId": "book-economy",
              "renderingParameters": {
                "x": 1548,
                "y": 24
              }
            },
            "book_international": {
              "name": "Book international shipment",
              "stepType": "Agent",
              "agentId": "shipping",
              "capabilityId": "book-international",
              "renderingParameters": {
                "x": 1548,
                "y": 120
              }
            },
            "manual_freight_review": {
              "name": "Call manual freight review",
              "description": "Escalate unusual dimensions or missing carrier quotes.",
              "stepType": "EmbedWorkflow",
              "childWorkflowId": "manual-freight-review",
              "childVersion": 4,
              "renderingParameters": {
                "x": 1548,
                "y": 216
              }
            },
            "wait_pick_confirm": {
              "name": "Wait for pick confirmation",
              "description": "Pause this order until warehouse confirms the pick ticket.",
              "stepType": "WaitForSignal",
              "responseSchema": {
                "pickedAt": {
                  "type": "string"
                },
                "pickerId": {
                  "type": "string"
                }
              },
              "timeoutMs": {
                "valueType": "immediate",
                "value": 900000,
                "type": "number"
              },
              "pollIntervalMs": 5000,
              "renderingParameters": {
                "x": 1764,
                "y": 24
              }
            },
            "create_backorder": {
              "name": "Create backorder",
              "description": "Create a backorder when stock is not currently available.",
              "stepType": "Agent",
              "agentId": "inventory",
              "capabilityId": "create-backorder",
              "inputMapping": {
                "order": {
                  "valueType": "reference",
                  "value": "{{ variables.order }}",
                  "type": "json"
                }
              },
              "renderingParameters": {
                "x": 900,
                "y": 252
              }
            },
            "notify_customer_backorder": {
              "name": "Notify customer about backorder",
              "stepType": "Agent",
              "agentId": "messaging",
              "capabilityId": "send-backorder-email",
              "renderingParameters": {
                "x": 1116,
                "y": 252
              }
            },
            "finish_order_iteration": {
              "name": "Finish order iteration",
              "description": "Return the fulfillment result for this order.",
              "stepType": "Finish",
              "renderingParameters": {
                "x": 1980,
                "y": 120
              }
            }
          },
          "executionPlan": [
            {
              "fromStep": "classify_order",
              "toStep": "deliver_digital",
              "label": "digital"
            },
            {
              "fromStep": "classify_order",
              "toStep": "wholesale_subflow",
              "label": "wholesale"
            },
            {
              "fromStep": "classify_order",
              "toStep": "apply_fragile_packaging",
              "label": "fragile"
            },
            {
              "fromStep": "classify_order",
              "toStep": "lookup_inventory",
              "label": "default"
            },
            {
              "fromStep": "apply_fragile_packaging",
              "toStep": "lookup_inventory",
              "label": "next"
            },
            {
              "fromStep": "wholesale_subflow",
              "toStep": "lookup_inventory",
              "label": "next"
            },
            {
              "fromStep": "deliver_digital",
              "toStep": "finish_order_iteration",
              "label": "next"
            },
            {
              "fromStep": "lookup_inventory",
              "toStep": "inventory_available",
              "label": "next"
            },
            {
              "fromStep": "inventory_available",
              "toStep": "reserve_stock",
              "label": "true"
            },
            {
              "fromStep": "inventory_available",
              "toStep": "create_backorder",
              "label": "false"
            },
            {
              "fromStep": "reserve_stock",
              "toStep": "quote_carriers",
              "label": "next"
            },
            {
              "fromStep": "quote_carriers",
              "toStep": "choose_carrier_lane",
              "label": "next"
            },
            {
              "fromStep": "choose_carrier_lane",
              "toStep": "book_express",
              "label": "express"
            },
            {
              "fromStep": "choose_carrier_lane",
              "toStep": "book_economy",
              "label": "economy"
            },
            {
              "fromStep": "choose_carrier_lane",
              "toStep": "book_international",
              "label": "international"
            },
            {
              "fromStep": "choose_carrier_lane",
              "toStep": "manual_freight_review",
              "label": "default"
            },
            {
              "fromStep": "book_express",
              "toStep": "wait_pick_confirm",
              "label": "next"
            },
            {
              "fromStep": "book_economy",
              "toStep": "wait_pick_confirm",
              "label": "next"
            },
            {
              "fromStep": "book_international",
              "toStep": "wait_pick_confirm",
              "label": "next"
            },
            {
              "fromStep": "manual_freight_review",
              "toStep": "wait_pick_confirm",
              "label": "next"
            },
            {
              "fromStep": "wait_pick_confirm",
              "toStep": "finish_order_iteration",
              "label": "next"
            },
            {
              "fromStep": "create_backorder",
              "toStep": "notify_customer_backorder",
              "label": "next"
            },
            {
              "fromStep": "notify_customer_backorder",
              "toStep": "finish_order_iteration",
              "label": "next"
            }
          ]
        },
        "renderingParameters": {
          "x": 1020,
          "y": 96,
          "width": 2244,
          "height": 612
        }
      },
      "aggregate_results": {
        "name": "Aggregate fulfillment results",
        "description": "Combine all split iteration results into a batch summary.",
        "stepType": "Agent",
        "agentId": "fulfillment",
        "capabilityId": "aggregate-results",
        "inputMapping": {
          "results": {
            "valueType": "reference",
            "value": "{{ steps.split_orders.output }}",
            "type": "json"
          }
        },
        "renderingParameters": {
          "x": 3336,
          "y": 96
        }
      },
      "has_backorders": {
        "name": "Any backorders?",
        "description": "Branch notifications and reconciliation when stock was missing.",
        "stepType": "Conditional",
        "condition": {
          "operator": "gt",
          "left": "{{ steps.aggregate_results.output.backorderedOrders }}",
          "right": 0
        },
        "renderingParameters": {
          "x": 3540,
          "y": 96
        }
      },
      "notify_backorders": {
        "name": "Notify operations about backorders",
        "stepType": "Agent",
        "agentId": "messaging",
        "capabilityId": "send-ops-alert",
        "inputMapping": {
          "summary": {
            "valueType": "reference",
