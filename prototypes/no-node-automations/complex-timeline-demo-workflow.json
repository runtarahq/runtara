      "reconcile_until_clean": {
        "name": "While reconciliation pending",
        "description": "Poll external systems until outstanding reconciliation issues clear.",
        "stepType": "While",
        "condition": {
          "operator": "gt",
          "left": "{{ steps.poll_reconciliation.output.pendingCount }}",
          "right": 0
        },
        "config": {
          "maxIterations": 5,
          "timeout": 600000
        },
        "subgraph": {
          "entryPoint": "poll_reconciliation",
          "steps": {
            "poll_reconciliation": {
              "name": "Poll reconciliation state",
              "stepType": "Agent",
              "agentId": "fulfillment",
              "capabilityId": "poll-reconciliation",
