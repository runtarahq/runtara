            "type": "json"
          }
        },
        "renderingParameters": {
          "x": 3744,
          "y": -24
        }
      },
      "sync_external_systems": {
        "name": "Split external system syncs",
        "description": "Push the final batch state to Shopify, ERP, warehouse, and email systems.",
        "stepType": "Split",
        "config": {
          "value": {
            "valueType": "immediate",
            "value": [
              "shopify",
              "erp",
              "warehouse",
              "email"
            ],
            "type": "json"
          },
          "parallelism": 4,
          "variables": {
            "system": {
              "valueType": "reference",
