{
  "name": "Timeline Stress Test - Fulfillment Orchestration",
  "description": "Complex sample workflow for validating the timeline renderer with branches, splits, nested scopes, switches, loops, and embedded workflow calls.",
  "executionGraph": {
    "name": "Timeline Stress Test - Fulfillment Orchestration",
    "description": "Complex sample workflow for validating the timeline renderer with branches, splits, nested scopes, switches, loops, and embedded workflow calls.",
    "entryPoint": "ingest_orders",
    "executionTimeoutSeconds": 1800,
    "variables": {
      "tenantId": {
        "type": "string",
        "value": "demo-tenant"
      },
      "warehouseRegion": {
        "type": "string",
        "value": "eu-central"
      },
      "dryRun": {
        "type": "boolean",
        "value": false
      }
    },
    "inputSchema": {
      "batchId": {
        "type": "string",
        "description": "Fulfillment batch to reconcile"
      },
      "priorityCutoff": {
        "type": "number",
        "description": "Priority score that separates standard and express handling"
      }
    },
    "outputSchema": {
      "processedOrders": {
        "type": "integer",
        "description": "Number of orders processed"
      },
      "backorderedOrders": {
        "type": "integer",
        "description": "Number of orders that could not be fulfilled immediately"
      },
      "syncStatus": {
        "type": "string",
        "description": "External system synchronization status"
      }
    },
    "steps": {
      "ingest_orders": {
        "name": "Ingest open orders",
        "description": "Load all open orders for the requested batch.",
        "stepType": "Agent",
        "agentId": "orders-api",
        "capabilityId": "list-open-orders",
        "inputMapping": {
          "batchId": {
            "valueType": "reference",
            "value": "{{ input.batchId }}",
            "type": "string"
          },
          "tenantId": {
            "valueType": "reference",
            "value": "{{ variables.tenantId }}",
            "type": "string"
          }
        },
        "renderingParameters": {
          "x": 0,
          "y": 96
        }
      },
      "normalize_orders": {
        "name": "Normalize order payloads",
        "description": "Flatten customer, line item, shipping, and payment fields.",
        "stepType": "Agent",
        "agentId": "orders-api",
        "capabilityId": "normalize-orders",
        "inputMapping": {
          "orders": {
            "valueType": "reference",
            "value": "{{ steps.ingest_orders.output.orders }}",
            "type": "json"
          }
        },
        "renderingParameters": {
          "x": 204,
          "y": 96
        }
      },
      "screen_fraud": {
        "name": "Screen fraud risk",
        "description": "Branch the batch when any order has high fraud or payment risk.",
        "stepType": "Conditional",
        "condition": {
          "operator": "gt",
          "left": "{{ steps.normalize_orders.output.maxRiskScore }}",
          "right": 80
        },
        "renderingParameters": {
          "x": 408,
          "y": 96
        }
      },
      "fraud_review_workflow": {
        "name": "Call fraud review workflow",
        "description": "Run the existing manual fraud review scenario before fulfillment.",
        "stepType": "EmbedWorkflow",
        "childWorkflowId": "fraud-review-v2",
        "childVersion": "latest",
        "inputMapping": {
          "orders": {
            "valueType": "reference",
            "value": "{{ steps.normalize_orders.output.flaggedOrders }}",
            "type": "json"
          }
        },
        "renderingParameters": {
          "x": 612,
          "y": -36
        }
      },
      "fraud_review_approved": {
        "name": "Fraud review approved?",
        "description": "Continue only if the embedded review scenario clears the orders.",
        "stepType": "Conditional",
        "condition": {
          "operator": "eq",
          "left": "{{ steps.fraud_review_workflow.output.status }}",
          "right": "approved"
        },
        "renderingParameters": {
          "x": 816,
          "y": -36
        }
      },
      "reject_risky_batch": {
        "name": "Reject risky batch",
        "description": "Stop fulfillment and return the review reason.",
        "stepType": "Finish",
        "inputMapping": {
          "status": {
            "valueType": "immediate",
            "value": "rejected",
            "type": "string"
          },
          "reason": {
            "valueType": "reference",
            "value": "{{ steps.fraud_review_workflow.output.reason }}",
            "type": "string"
          }
        },
        "renderingParameters": {
          "x": 1020,
          "y": -144
        }
      },
      "split_orders": {
        "name": "Split by order",
        "description": "Fulfill every normalized order with per-order routing and branch handling.",
        "stepType": "Split",
        "config": {
          "value": {
            "valueType": "reference",
            "value": "{{ steps.normalize_orders.output.orders }}",
            "type": "json"
          },
          "parallelism": 6,
          "dontStopOnFailed": true,
          "variables": {
            "order": {
              "valueType": "reference",
              "value": "{{ item }}",
              "type": "json"
            },
            "region": {
              "valueType": "reference",
              "value": "{{ variables.warehouseRegion }}",
              "type": "string"
            }
          }
        },
        "inputSchema": {
          "order": {
            "type": "object",
            "description": "Single normalized order"
          }
        },
        "outputSchema": {
          "orderId": {
            "type": "string"
          },
          "fulfillmentStatus": {
            "type": "string"
          },
          "trackingNumber": {
            "type": "string"
          }
        },
        "subgraph": {
          "entryPoint": "classify_order",
          "steps": {
            "classify_order": {
              "name": "Classify order route",
              "description": "Route digital, wholesale, fragile, and standard orders.",
              "stepType": "Switch",
              "config": {
                "value": {
                  "valueType": "reference",
                  "value": "{{ variables.order.type }}",
                  "type": "string"
                },
                "cases": [
                  {
                    "match": "digital",
                    "matchType": "EQ",
                    "output": {
                      "lane": "digital"
                    },
                    "route": "digital"
                  },
                  {
                    "match": "wholesale",
                    "matchType": "EQ",
                    "output": {
                      "lane": "wholesale"
                    },
                    "route": "wholesale"
                  },
                  {
                    "match": "fragile",
                    "matchType": "EQ",
                    "output": {
                      "lane": "fragile"
                    },
                    "route": "fragile"
                  }
                ],
                "default": {
                  "lane": "standard"
                }
              },
              "renderingParameters": {
                "x": 36,
                "y": 120
              }
            },
            "deliver_digital": {
              "name": "Deliver digital entitlement",
              "description": "Provision license or download access for digital orders.",
              "stepType": "Agent",
              "agentId": "digital-delivery",
              "capabilityId": "provision-entitlement",
              "inputMapping": {
                "order": {
                  "valueType": "reference",
                  "value": "{{ variables.order }}",
                  "type": "json"
                }
              },
              "renderingParameters": {
                "x": 252,
                "y": 0
              }
            },
            "wholesale_subflow": {
              "name": "Call wholesale approval",
              "description": "Delegate wholesale orders to the contract pricing workflow.",
              "stepType": "EmbedWorkflow",
              "childWorkflowId": "wholesale-approval-v3",
              "childVersion": "current",
              "inputMapping": {
                "order": {
                  "valueType": "reference",
                  "value": "{{ variables.order }}",
                  "type": "json"
                }
              },
              "renderingParameters": {
                "x": 252,
                "y": 108
              }
            },
            "apply_fragile_packaging": {
              "name": "Apply fragile packaging",
              "description": "Add protective packing material and handling instructions.",
              "stepType": "Agent",
              "agentId": "warehouse",
              "capabilityId": "prepare-fragile-pack",
              "inputMapping": {
                "order": {
                  "valueType": "reference",
                  "value": "{{ variables.order }}",
                  "type": "json"
                }
              },
              "renderingParameters": {
                "x": 252,
                "y": 216
              }
            },
            "lookup_inventory": {
              "name": "Lookup available inventory",
              "description": "Find stock for the line items in the selected region.",
              "stepType": "Agent",
              "agentId": "inventory",
              "capabilityId": "lookup-availability",
              "inputMapping": {
                "skuLines": {
                  "valueType": "reference",
                  "value": "{{ variables.order.lines }}",
                  "type": "json"
                },
                "region": {
                  "valueType": "reference",
                  "value": "{{ variables.region }}",
                  "type": "string"
                }
              },
              "renderingParameters": {
                "x": 468,
                "y": 120
              }
            },
            "inventory_available": {
              "name": "Inventory available?",
              "description": "Branch fulfilled orders from backorders.",
              "stepType": "Conditional",
              "condition": {
                "operator": "eq",
                "left": "{{ steps.lookup_inventory.output.available }}",
                "right": true
              },
              "renderingParameters": {
                "x": 684,
                "y": 120
              }
            },
            "reserve_stock": {
              "name": "Reserve stock",
