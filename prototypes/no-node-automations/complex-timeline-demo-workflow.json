                "x": 36,
                "y": 120
              }
            },
            "repair_drift": {
              "name": "Repair detected drift",
              "stepType": "Agent",
              "agentId": "fulfillment",
              "capabilityId": "repair-drift",
              "renderingParameters": {
                "x": 252,
                "y": 120
              }
            },
            "loop_iteration_done": {
              "name": "Loop iteration done",
              "stepType": "Finish",
              "renderingParameters": {
                "x": 468,
                "y": 120
              }
            }
          },
          "executionPlan": [
            {
              "fromStep": "poll_reconciliation",
              "toStep": "repair_drift",
              "label": "next"
            },
            {
