          "value": {
            "valueType": "reference",
            "value": "steps.normalize_orders.output.orders",
            "type": "json"
          },
          "parallelism": 6,
          "dontStopOnFailed": true,
          "variables": {
            "order": {
              "valueType": "reference",
              "value": "item",
              "type": "json"
            },
            "region": {
              "valueType": "reference",
              "value": "variables.warehouseRegion",
              "type": "string"
            }
          }
        },
        "inputSchema": {
          "order": {
            "type": "object",
            "description": "Single normalized order"
          }
        },
        "outputSchema": {
          "orderId": {
            "type": "string"
          },
          "fulfillmentStatus": {
            "type": "string"
          },
          "trackingNumber": {
            "type": "string"
          }
        },
