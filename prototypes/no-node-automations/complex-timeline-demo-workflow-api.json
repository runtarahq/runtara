{
  "name": "Timeline Stress Test - Fulfillment Orchestration",
  "description": "Complex sample workflow for validating the timeline renderer with branches, splits, nested scopes, switches, loops, and embedded workflow calls.",
  "executionGraph": {
    "name": "Timeline Stress Test - Fulfillment Orchestration",
    "description": "Complex sample workflow for validating the timeline renderer with branches, splits, nested scopes, switches, loops, and embedded workflow calls.",
    "entryPoint": "ingest_orders",
    "executionTimeoutSeconds": 1800,
    "variables": {
      "tenantId": {
        "type": "string",
        "value": "demo-tenant"
      },
      "warehouseRegion": {
        "type": "string",
        "value": "eu-central"
      },
      "dryRun": {
        "type": "boolean",
        "value": false
      }
    },
    "inputSchema": {
      "batchId": {
        "type": "string",
        "description": "Fulfillment batch to reconcile"
      },
      "priorityCutoff": {
        "type": "number",
        "description": "Priority score that separates standard and express handling"
      }
    },
    "outputSchema": {
      "processedOrders": {
        "type": "integer",
        "description": "Number of orders processed"
      },
      "backorderedOrders": {
        "type": "integer",
        "description": "Number of orders that could not be fulfilled immediately"
      },
      "syncStatus": {
        "type": "string",
        "description": "External system synchronization status"
      }
    },
    "steps": {
      "ingest_orders": {
        "name": "Ingest open orders",
        "stepType": "Agent",
        "agentId": "utils",
        "capabilityId": "return-input",
        "inputMapping": {
          "value": {
            "valueType": "composite",
            "value": {
              "batchId": {
                "valueType": "reference",
                "value": "input.batchId",
                "type": "string"
              },
              "tenantId": {
                "valueType": "reference",
                "value": "variables.tenantId",
                "type": "string"
              }
            }
          }
        },
        "id": "ingest_orders"
      },
      "normalize_orders": {
        "name": "Normalize order payloads",
        "stepType": "Agent",
        "agentId": "utils",
        "capabilityId": "return-input",
        "inputMapping": {
          "value": {
            "valueType": "composite",
            "value": {
              "orders": {
                "valueType": "reference",
                "value": "steps.ingest_orders.output.orders",
                "type": "json"
              }
            }
          }
        },
        "id": "normalize_orders"
      },
      "screen_fraud": {
        "name": "Screen fraud risk",
        "stepType": "Conditional",
        "condition": {
          "type": "operation",
          "op": "GT",
          "arguments": [
            {
              "valueType": "reference",
              "value": "steps.normalize_orders.output.maxRiskScore"
            },
            {
              "valueType": "immediate",
              "value": 80
            }
          ]
        },
        "id": "screen_fraud"
      },
      "fraud_review_workflow": {
        "name": "Call fraud review workflow",
        "stepType": "EmbedWorkflow",
        "childWorkflowId": "e41e668b-7e14-4212-97af-b331b9fd31a1",
        "childVersion": "latest",
        "inputMapping": {
          "value": {
            "valueType": "composite",
            "value": {
              "orders": {
                "valueType": "reference",
                "value": "steps.normalize_orders.output.flaggedOrders",
                "type": "json"
              }
            }
          }
        },
        "id": "fraud_review_workflow"
      },
      "fraud_review_approved": {
        "name": "Fraud review approved?",
        "stepType": "Conditional",
        "condition": {
          "type": "operation",
          "op": "EQ",
          "arguments": [
            {
              "valueType": "reference",
              "value": "steps.fraud_review_workflow.output.status"
            },
            {
              "valueType": "immediate",
              "value": "approved"
            }
          ]
        },
        "id": "fraud_review_approved"
      },
      "reject_risky_batch": {
        "name": "Reject risky batch",
        "stepType": "Finish",
        "inputMapping": {
          "status": {
            "valueType": "immediate",
            "value": "rejected"
          },
          "reason": {
            "valueType": "reference",
            "value": "steps.fraud_review_workflow.output.reason",
            "type": "string"
          }
        },
        "id": "reject_risky_batch"
      },
      "split_orders": {
